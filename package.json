{
  "name": "shadowvault",
  "version": "1.0.0",
  "description": "ShadowVault - A privacy-preserving deposit vault on Midnight",
  "type": "module",
  "scripts": {
    "compile": "compact compile contracts/shadow-vault.compact src/managed/shadow-vault",
    "deploy:local": "MIDNIGHT_NETWORK=local npx tsx src/deploy.ts",
